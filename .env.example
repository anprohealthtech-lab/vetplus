# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# PDF Generation
# Set to 'false' to use PDF.co exclusively (default: true)
VITE_USE_PUPPETEER=true
# PDF.co API Key (fallback for complex PDFs)
VITE_PDF_CO_API_KEY=your_pdf_co_api_key

# WhatsApp Backend API
VITE_WHATSAPP_API_BASE_URL=https://lionfish-app-nmodi.ondigitalocean.app
VITE_WHATSAPP_API_MODE=rest # or supabase-functions or netlify-functions

# CKEditor Premium / CKBox
VITE_CKEDITOR_LICENSE_KEY=your_ckeditor_license_key
VITE_CKEDITOR_TOKEN_URL=https://your-site/.netlify/functions/ckeditor-token
VITE_CKEDITOR_AI_API_KEY=optional_ai_key_if_enabled
CKBOX_ENVIRONMENT_ID=your_ckbox_environment_id
CKBOX_ACCESS_KEY=your_ckbox_access_key

# Example:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here