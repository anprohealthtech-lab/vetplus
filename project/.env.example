# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Custom Storage Domain (Optional - for branded PDF URLs)
# If set, report PDFs will use custom domain instead of default Supabase storage URLs
# Example: https://reports.limsapp.in
VITE_CUSTOM_STORAGE_DOMAIN=

# PDF Generation
# NOTE: Invoice PDF generation uses Supabase Edge Function (secure server-side)
# Set PDFCO_API_KEY in Supabase Edge Function secrets instead:
#   supabase secrets set PDFCO_API_KEY=your_api_key
# Get free API key at: https://pdf.co (300 PDFs/month free)

# Puppeteer Service (for report PDFs only)
# Set to 'false' to use PDF.co exclusively (default: true)
VITE_USE_PUPPETEER=true
# PDF.co API Key (fallback for complex report PDFs)
VITE_PDF_CO_API_KEY=your_pdf_co_api_key

# WhatsApp Backend API
VITE_WHATSAPP_API_BASE_URL=https://lionfish-app-nmodi.ondigitalocean.app
VITE_WHATSAPP_API_MODE=rest # or supabase-functions or netlify-functions

# CKEditor Premium / CKBox
VITE_CKEDITOR_LICENSE_KEY=your_ckeditor_license_key
VITE_CKEDITOR_TOKEN_URL=https://your-site/.netlify/functions/ckeditor-token
VITE_CKEDITOR_AI_API_KEY=optional_ai_key_if_enabled
CKBOX_ENVIRONMENT_ID=your_ckbox_environment_id
CKBOX_ACCESS_KEY=your_ckbox_access_key

# Example:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here